# Local working files (operating notes, drafts, personal backlog — never committed)
CLAUDE.md
backlog.md
_context/

# Project-local toolchain — `make dev-setup` rehydrates ./bin/ from
# scripts/install-tools.sh (pinned versions + SHA256). Never committed.
/bin/

# Backend config — generated by `make regenerate-backend` from bootstrap's
# outputs (account-specific bucket name + region). Derived, not source.
/backend.hcl

# Go build artifacts
*.exe
*.dll
*.so
*.dylib
*.test
*.out
/greeter
/app/greeter
vendor/

# Terraform
.terraform/
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
!example.tfvars
# Pattern X (multi-region topology as data): repo-root config is the single
# source of truth, consumed by TF (via -var-file) + Makefile/CI (via jq).
# JSON form because both TF and jq parse it natively + per-entry `enabled`
# boolean replaces commented-out template semantics (JSON has no comments).
!regions.auto.tfvars.json
# .terraform.lock.hcl is intentionally NOT ignored — HashiCorp guidance is to
# commit it per-env so provider versions are pinned + reproducible.
crash.log
crash.*.log

# DR drill — the raw Terraform CLI log carries account-specific ARNs / IDs, so
# it is kept operator-local. The curated DR_REPORT.md and the failover-probe
# log (timestamps + HTTP codes only) ARE committed as evidence.
docs/evidence/dr-drill-*.log

# AWS / secrets
.env
.env.*
*.pem
*.key
.aws/
credentials

# Container / image artifacts
*.tar
*.tar.gz

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store

# Layer-2 cloud-mutation hook transient state (incident 2026-06-06)
.claude/.cloud-mutation-open
.claude/.abandon-ok
