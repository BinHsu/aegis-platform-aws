// terraform/envs/platform/secrets.auto.tfvars.example
//
// Forker template. Copy to `secrets.auto.tfvars` in this directory (the
// real file is gitignored by the *.tfvars rule in .gitignore) and fill
// in real values from your Grafana Cloud stack + GitHub PAT settings.
//
// `terraform` auto-loads any *.auto.tfvars in the working dir, so once
// the real file is in place no -var flags are needed.
//
// CI does NOT read this file — see .github/workflows/infra-plan.yml and
// infra-apply.yml env: blocks; equivalent values live in GitHub Actions
// secrets (set via `gh secret set <NAME> -b <value>`).

// glc_ Cloud Access Policy token — Connections → Cloud Access Policies →
// create token with metrics/logs/traces/profiles write scope. Used as the
// Alloy remote_write password.
grafana_cloud_api_token = "glc_..."

// glsa_ Grafana instance service-account token — Administration → Users
// and access → Service accounts → new SA (role: Admin) → Add token. Used
// as auth for the `grafana` TF provider (dashboards / folders / alerts).
grafana_auth_token = "glsa_..."

// Connections → for each backend's "Send …" page. Each backend has its
// own instance-ID username (they differ). Mimir URL = the data-source
// URL + /push. Tempo URL = the OTLP gRPC host:port (no scheme/path).
grafana_cloud_mimir_url          = "https://prometheus-prod-XX-prod-<region>.grafana.net/api/prom/push"
grafana_cloud_mimir_username     = "<mimir-instance-id>"
grafana_cloud_loki_url           = "https://logs-prod-XXX.grafana.net/loki/api/v1/push"
grafana_cloud_loki_username      = "<loki-instance-id>"
grafana_cloud_tempo_url          = "tempo-prod-XX-prod-<region>.grafana.net:443"
grafana_cloud_tempo_username     = "<tempo-instance-id>"
grafana_cloud_pyroscope_url      = "https://profiles-prod-XXX.grafana.net"
grafana_cloud_pyroscope_username = "<pyroscope-instance-id>"

// AWS Budget alarm notification target — also reused by Grafana
// contact_point for alert routing.
budget_alert_email = "ops@example.com"

// GitHub fine-grained PAT with `admin:public_key` scope on the
// aegis-stateless repo. Used by `github_repository_deploy_key` (one
// per region, registered by regional-stack module so ArgoCD can pull
// this repo over SSH via a read-only deploy key).
github_token = "github_pat_..."

// ---- CloudWatch data source (Tier B) — OPTIONAL, off by default ----------
// Surfaces out-of-band infra health (EC2 status checks, ALB 5xx / healthy
// hosts) via a Grafana CloudWatch data source. Leave disabled unless you
// want it: it needs a cross-account IAM trust to Grafana Cloud's AWS
// account. To enable — in the Grafana Cloud UI, Connections → Add new
// connection → CloudWatch → set up via an IAM role; that screen shows the
// AWS account ID + external ID. Put them below and flip the flag:
//
// enable_cloudwatch_datasource = true
// grafana_cloud_aws_account_id = "<shown in the GC CloudWatch setup>"
// grafana_cloud_external_id    = "<shown in the GC CloudWatch setup>"
