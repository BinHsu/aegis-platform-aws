// terraform/envs/regional/secrets.auto.tfvars.example
//
// Forker template. Copy to `secrets.auto.tfvars` in this directory (the
// real file is gitignored by the *.tfvars rule in .gitignore) and fill
// the GitHub PAT below.
//
// This env's other inputs (region / vpc_cidr / node_* / tfstate_bucket
// / tfstate_region / platform_region) are injected by the Makefile or
// GH Actions workflow at apply time — no need to set them here.

// Same PAT as platform/'s github_token (one place per env that needs
// it; could be centralized via SSM in a follow-up).
github_token = "github_pat_..."

// Human operator's IAM principal ARN — gets an explicit EKS ClusterAdmin
// access entry. `aws sts get-caller-identity --query Arn`. Must match the
// GH Actions secret OPERATOR_PRINCIPAL_ARN (the access-entry set has to be
// deterministic regardless of who runs terraform).
operator_principal_arn = "arn:aws:iam::<account-id>:user/<you>"
